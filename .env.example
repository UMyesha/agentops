# ─── Database ────────────────────────────────────────────────────────────────
# Matches docker-compose.yml credentials.
DATABASE_URL="postgresql://agentops:agentops@localhost:5432/agentops?schema=public"

# ─── Auth.js (NextAuth v5) ───────────────────────────────────────────────────
# Generate with: npx auth secret   (or: openssl rand -base64 32)
AUTH_SECRET="change-me-in-production"
# Base URL of the app (used for callbacks).
AUTH_URL="http://localhost:3000"

# GitHub OAuth (optional for local dev — credentials login works without it).
# Create an OAuth app at https://github.com/settings/developers
AUTH_GITHUB_ID=""
AUTH_GITHUB_SECRET=""

# ─── AI provider ─────────────────────────────────────────────────────────────
# "mock"  -> deterministic, free, no API key (default; used for seeds + demos)
# "openai" -> real OpenAI calls (requires OPENAI_API_KEY)
AI_PROVIDER="mock"
OPENAI_API_KEY=""
OPENAI_MODEL="gpt-4o-mini"

# ─── Queue & worker (Phase 5) ────────────────────────────────────────────────
# Execution runs in a standalone BullMQ worker (`npm run worker`). The web app
# only enqueues; it never runs a Worker.
REDIS_URL="redis://localhost:6379"
AGENT_RUN_MAX_ATTEMPTS="3"          # total BullMQ attempts for transient failures
AGENT_RUN_BACKOFF_MS="1000"         # exponential backoff base delay
AGENT_WORKER_CONCURRENCY="2"        # jobs processed in parallel by one worker
AGENT_WORKER_LOCK_DURATION_MS="30000"  # BullMQ lock duration; also used for job.extendLock

# Test-only: enables the mock provider's synthetic transient-failure phrases
# ("simulate transient failure once" / "... always"). Active ONLY when
# AI_PROVIDER=mock AND this is "true". MUST stay false in production.
AGENTOPS_ENABLE_RETRY_TEST_TRIGGERS="false"

# ─── Demo mode ───────────────────────────────────────────────────────────────
# When "true", the login page reveals and prefills the seeded demo credentials
# and shows a short "what's in the demo" note. When "false" (default) the login
# form is blank with no credential hint. The marketing landing page is static
# and NOT affected by this flag. MUST stay false for any non-demo deployment.
AGENTOPS_DEMO_MODE="false"

# ─── Demo credentials (seeded user) ──────────────────────────────────────────
DEMO_USER_EMAIL="demo@agentops.dev"
DEMO_USER_PASSWORD="demo1234"
